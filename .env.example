# SwarmSync Agents Gateway — environment variable reference

# ============================================================================
# Genesis Agents (marketplace runtime — swarmsync-agents service only)
# ============================================================================

# Ed25519 signing keypair for VCAP wrapper JWTs.
# Generate with:
#   python -c "import base64; from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; from cryptography.hazmat.primitives import serialization; k = Ed25519PrivateKey.generate(); priv = base64.b64encode(k.private_bytes(serialization.Encoding.Raw, serialization.PrivateFormat.Raw, serialization.NoEncryption())).decode(); pub = base64.b64encode(k.public_key().public_bytes(serialization.Encoding.Raw, serialization.PublicFormat.Raw)).decode(); print('PRIV:', priv); print('PUB:', pub)"
# Without these, proofs are emitted unsigned (alg=none) — fine for dev, not for production.
GENESIS_GATEWAY_PRIVKEY_B64=
GENESIS_GATEWAY_PUBKEY_B64=

# AES-256-GCM key for encrypting buyer Conduit browser sessions at rest.
# 32 random bytes, base64-encoded. Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Without this, /jobs/{job_id}/session returns vault_not_configured and
# Concierge Mode is disabled (output-only delivery still works).
GENESIS_SESSION_VAULT_KEY=

# Comma-separated admin email allowlist for /admin/* endpoints.
# Defaults to bullrushinvestments@gmail.com if unset.
SWARMSYNC_ADMIN_EMAILS=bullrushinvestments@gmail.com

# ============================================================================
# Auth — required for production deployments
# ============================================================================

# Public API key checked on every /agents/{slug}/run, /a2a, /jobs/* request
# via the X-Agent-Api-Key header. If unset, the gateway is open (dev mode).
# Must match AGENTS_GATEWAY_API_KEY on swarmsync-api AND the GATEWAY_API_KEY
# stored in Cato's vault.
GATEWAY_API_KEY=

# Shared secret for internal swarmsync-api → agents-gateway calls.
# swarmsync-api's executeAgent() sends this as x-agent-gateway-secret.
# Must match AGENT_GATEWAY_SECRET on swarmsync-api.
# verify_gateway_key accepts EITHER GATEWAY_API_KEY or AGENT_GATEWAY_SECRET.
AGENT_GATEWAY_SECRET=

# LLM endpoint configuration.
# Genesis defaults to SwarmSync's router URL and a concrete MiniMax model so
# bundle-backed agents do not silently fall through to OpenRouter's credit path.
# OpenRouter is only available if GENESIS_ALLOW_OPENROUTER_FALLBACK=true.
LLM_API_URL=https://api.swarmsync.ai/v1/chat/completions
LLM_API_KEY=
# Pass `auto` through to SwarmSync Routing so complexity scoring can choose
# the right economy/mid/premium model tier per request. Set a concrete model
# only when you intentionally want to bypass smart routing.
GENESIS_LLM_MODEL=auto
GENESIS_ALLOW_OPENROUTER_FALLBACK=false

# Platform fee skim — 10% of paid invocations routes to the treasury.
# X402_PLATFORM_WALLET_ADDRESS lives in the existing payments config.
SWARMSYNC_PLATFORM_FEE_PCT=0.10

# Postgres-backed job store + worker queue.
# DATABASE_URL is shared with the API service.
WORKER_CONCURRENCY=3
WORKER_POLL_INTERVAL_S=2
WORKER_HEARTBEAT_INTERVAL_S=20
WORKER_STALE_CHECK_INTERVAL_S=60

# Optional — fallback to S3 if local Render disk insufficient
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# GENESIS_S3_BUCKET=swarmsync-genesis-artifacts
# GENESIS_SIGNED_URL_TTL_SECONDS=604800
